{
  "manifest_version": 3,
  "name": "AreYouSure?",
  "version": "1.0",
  "description": "Your laptop is disappointed in you.",
  "permissions": ["tabs", "storage", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "blocked.html"
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}